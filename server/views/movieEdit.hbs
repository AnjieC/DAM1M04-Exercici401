<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        {{> header}}
        <title>Editar: {{movie.title}}</title>
    </head>
    <body>
        {{> menu}}
        <section class="contenido detalles">
            <div>
                <img src="/imatges/caratula.png" alt="caratula">
            </div>
            <div>
                <form method="POST" action="/editarPeli">
                    <input type="hidden" name="table" value="film">
                    <input type="hidden" name="film_id" value="{{movie.film_id}}">
                    <label for="nombre">Nombre:</label>
                    <input type="text" id="nombre" name="nombre" value="{{movie.title}}" required>
                    <br>
                    <label for="description">Descripción:</label>
                    <textarea name="description" id="description" rows="5" cols="60">{{movie.description}}</textarea>
                    <br>
                    <label for="year">Año:</label>
                    <input type="number" id="year" name="year" value="{{movie.release_year}}" required>
                    <br>
                    <label for="language">Idioma:</label>
                    <select name="language" id="language">
                        {{#each languages}}
                            <option value="{{language_id}}" {{#if (eq language_id ../movie.language_id)}}selected{{/if}}>
                                {{name}}
                            </option>
                        {{/each}}
                    </select>
                    <br>
                    <label for="length">Duración:</label>
                    <input type="number" id="length" name="length" value="{{movie.length}}" required>
                    <br>
                    <label for="rating">Rating:</label>
                    <input type="text" id="rating" name="rating" value="{{movie.rating}}" required>
                    <br><br>
                    <button type="submit" class="add">Guardar cambios</button>
                </form>
                <form method="POST" action="/esborrarPeli">
                    <input type="hidden" name="film_id" value="{{movie.film_id}}">
                    <button type="submit" class="borrar">Borrar Película</button>
                </form>
                <a href="/movie?id={{movie.film_id}}" class="cancelar"><button>Cancelar</button></a>
            </div>
        </section>
        {{> footer}}
    </body>
</html>